---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<section class="bg-black py-24" id="projects">
  <div class="mx-auto max-w-7xl px-5">
    <div class="mb-16 text-center">
      <h2 class="mb-4 font-serif text-4xl font-bold text-white md:text-5xl">
        Featured Projects
      </h2>
      <p class="mx-auto max-w-2xl text-xl text-gray-400">
        A showcase of my recent work and contributions
      </p>
    </div>

    <!-- Category Filter Bar -->
    <div
      class="mb-12 flex flex-wrap justify-center gap-3"
      role="group"
      aria-label="Filter projects by category"
      id="project-filters"
    >
      <button
        type="button"
        data-filter="all"
        aria-pressed="true"
        class="filter-btn active inline-flex items-center gap-2 rounded-full border border-transparent bg-gradient-to-r from-pink-500 to-purple-600 px-5 py-2.5 text-sm font-medium text-white transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-pink-500/25"
      >
        All
      </button>
      <button
        type="button"
        data-filter="web"
        aria-pressed="false"
        class="filter-btn inline-flex items-center gap-2 rounded-full border border-gray-700 bg-gray-900/50 px-5 py-2.5 text-sm font-medium text-gray-300 transition-all duration-300 hover:border-purple-500/50 hover:text-white"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <rect x="2" y="3" width="20" height="14" rx="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
        Web
      </button>
      <button
        type="button"
        data-filter="mobile"
        aria-pressed="false"
        class="filter-btn inline-flex items-center gap-2 rounded-full border border-gray-700 bg-gray-900/50 px-5 py-2.5 text-sm font-medium text-gray-300 transition-all duration-300 hover:border-purple-500/50 hover:text-white"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
          <line x1="12" y1="18" x2="12.01" y2="18"></line>
        </svg>
        Mobile
      </button>
      <button
        type="button"
        data-filter="system"
        aria-pressed="false"
        class="filter-btn inline-flex items-center gap-2 rounded-full border border-gray-700 bg-gray-900/50 px-5 py-2.5 text-sm font-medium text-gray-300 transition-all duration-300 hover:border-purple-500/50 hover:text-white"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="8" rx="2"></rect>
          <rect x="2" y="14" width="20" height="8" rx="2"></rect>
          <line x1="6" y1="6" x2="6.01" y2="6"></line>
          <line x1="6" y1="18" x2="6.01" y2="18"></line>
        </svg>
        System
      </button>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3" id="projects-grid">
      {
        projects.map(
          ({
            name,
            summary,
            image,
            linkPreview,
            linkGooglePlay,
            linkAppStore,
            slug,
            categories = [],
            tech = [],
            imageFocalPoint = "center",
          }) => (
            <article
              data-categories={categories.join(",")}
              class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-700 bg-gradient-to-br from-gray-900 to-gray-800 shadow-xl transition-all duration-300 hover:border-purple-500/50 hover:shadow-2xl hover:shadow-purple-500/10"
            >
              {/* Project Image */}
              <div class="relative h-48 overflow-hidden">
                {slug ? (
                  <a href={`/projects/${slug}`} aria-label={`${name} details`}>
                    <Image
                      class={`h-full w-full object-cover object-${imageFocalPoint} transition-transform duration-500 group-hover:scale-110`}
                      src={image}
                      alt={name}
                      width="600"
                      height="350"
                      loading="lazy"
                    />
                    <div
                      class={`absolute inset-0 ${
                        name.includes("Good on You")
                          ? "bg-gradient-to-t from-black/40 via-transparent to-transparent"
                          : "bg-gradient-to-t from-black/60 via-transparent to-transparent"
                      }`}
                    />
                  </a>
                ) : (
                  <>
                    <img
                      class={`h-full w-full transition-transform duration-500 group-hover:scale-110 ${
                        name.includes("Good on You")
                          ? "object-cover object-top"
                          : "object-cover object-center"
                      }`}
                      src={image}
                      alt={name}
                      width="600"
                      height="350"
                      loading="lazy"
                    />
                    <div
                      class={`absolute inset-0 ${
                        name.includes("Good on You")
                          ? "bg-gradient-to-t from-black/40 via-transparent to-transparent"
                          : "bg-gradient-to-t from-black/60 via-transparent to-transparent"
                      }`}
                    />
                  </>
                )}
              </div>

              {/* Project Content */}
              <div class="flex h-full flex-col p-6">
                <div class="flex-grow space-y-4">
                  <h3 class="font-serif text-xl font-semibold text-white transition-colors duration-300 group-hover:text-purple-300">
                    {name}
                  </h3>

                  {/* Category Tags */}
                  {categories.length > 0 && (
                    <div class="flex flex-wrap gap-x-3 gap-y-1">
                      {categories.map((category: "web" | "mobile" | "system") => {
                        const dotColors = {
                          web: "bg-sky-400",
                          mobile: "bg-emerald-400",
                          system: "bg-purple-400",
                        };
                        const labels = {
                          web: "Web",
                          mobile: "Mobile",
                          system: "System",
                        };
                        return (
                          <span class="inline-flex items-center gap-1.5 text-xs text-gray-400">
                            <span
                              class={`h-1.5 w-1.5 rounded-full ${dotColors[category]}`}
                              aria-hidden="true"
                            />
                            {labels[category]}
                          </span>
                        );
                      })}
                    </div>
                  )}

                  <p class="line-clamp-4 text-sm leading-relaxed text-gray-300">
                    {summary}
                  </p>
                </div>

                <div class="mt-4 border-t border-gray-700/50" />

                {/* Action Buttons - Always at bottom */}
                <div class="mt-auto flex flex-wrap gap-3 pt-4">
                  {/* Preview Button */}
                  {linkPreview &&
                    !linkPreview.includes("apps.apple.com") &&
                    !linkPreview.includes("play.google.com") && (
                      <a
                        href={linkPreview}
                        target="_blank"
                        class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-pink-500 to-purple-600 px-4 py-2 text-xs font-medium text-white transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-pink-500/25"
                      >
                        <svg
                          class="h-4 w-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                          />
                        </svg>
                      </a>
                    )}

                  {/* App Store / Play Store Buttons */}
                  {(() => {
                    // Define store links with their types and labels
                    const storeLinks = [
                      {
                        type: "appStore",
                        url: linkAppStore,
                        label: "App Store",
                      },
                      {
                        type: "playStore",
                        url: linkGooglePlay,
                        label: "Play Store",
                      },
                    ].filter((link) => link.url);

                    if (storeLinks.length === 0) return null;

                    // Define icons for each store type
                    const icons = {
                      appStore: (
                        <svg
                          class="h-4 w-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                          />
                        </svg>
                      ),
                      playStore: (
                        <svg
                          class="h-4 w-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                          />
                        </svg>
                      ),
                    };

                    return storeLinks.map((link) => {
                      const icon = icons[link.type as keyof typeof icons];
                      return (
                        <a
                          href={link.url}
                          target="_blank"
                          class="inline-flex items-center gap-2 rounded-lg bg-gray-700 px-3 py-1.5 text-xs font-medium text-white transition-all duration-300 hover:scale-105 hover:bg-gray-600"
                          rel="noopener noreferrer"
                          title={`Download on ${link.label}`}
                        >
                          {icon}
                          {link.label}
                        </a>
                      );
                    });
                  })()}
                </div>
              </div>

              {/* Hover effect overlay */}
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-purple-900/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
            </article>
          ),
        )
      }

      <!-- Empty state -->
      <div
        id="projects-empty-state"
        class="col-span-full hidden py-12 text-center"
      >
        <p class="text-lg text-gray-400">No projects in this category yet.</p>
      </div>
    </div>

    <!-- Explore Projects Message -->
    <div class="mt-12 text-center">
      <p class="text-lg text-gray-400">
        Click on any project above to view detailed information
      </p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const filterBar = document.getElementById("project-filters");
    const cards = document.querySelectorAll("#projects-grid [data-categories]");
    const emptyState = document.getElementById("projects-empty-state");

    if (!filterBar || cards.length === 0) return;

    filterBar.addEventListener("click", function (event) {
      const button = event.target.closest("button[data-filter]");
      if (!button) return;

      const filter = button.dataset.filter;
      const isActive = button.classList.contains("active");

      // Clicking the active filter or "All" resets to showing all projects
      if (isActive || filter === "all") {
        applyFilter("all");
        return;
      }

      applyFilter(filter);
    });

    function applyFilter(filter) {
      const buttons = filterBar.querySelectorAll("button[data-filter]");

      buttons.forEach((btn) => {
        const active = btn.dataset.filter === filter;
        btn.classList.toggle("active", active);
        btn.setAttribute("aria-pressed", String(active));

        if (active) {
          btn.classList.remove(
            "border-gray-700",
            "bg-gray-900/50",
            "text-gray-300"
          );
          btn.classList.add(
            "border-transparent",
            "bg-gradient-to-r",
            "from-pink-500",
            "to-purple-600",
            "text-white"
          );
        } else {
          btn.classList.remove(
            "border-transparent",
            "bg-gradient-to-r",
            "from-pink-500",
            "to-purple-600",
            "text-white"
          );
          btn.classList.add(
            "border-gray-700",
            "bg-gray-900/50",
            "text-gray-300"
          );
        }
      });

      let visibleCount = 0;
      cards.forEach((card) => {
        const categories = (card.dataset.categories || "").split(",").filter(Boolean);
        const visible = filter === "all" || categories.includes(filter);
        card.style.display = visible ? "flex" : "none";
        if (visible) visibleCount++;
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    }
  })();
</script>